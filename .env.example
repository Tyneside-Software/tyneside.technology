# ── Server ──────────────────────────────────────────────
PORT=3000
# Public base URL of this site (no trailing slash). Used for success/cancel pages.
BASE_URL=http://localhost:3000

# ── Tide payments ───────────────────────────────────────
# Tide has no public "create checkout session" API like Stripe.
# Create Instant Checkout (or Payment Links) in the Tide app at the catalogue
# price for each laptop, then paste the full https://… link below.
#
# Tide app → Instant Checkout / Payment Links → share link
# https://www.tide.co/features/instant-checkout/
# https://www.tide.co/features/card-payments-links/

# £1 test stock (only in-stock SKU while laptops are OOS)
TIDE_LINK_TEST_1=

# Real laptops — currently out of stock on the storefront
TIDE_LINK_T14S_339=
TIDE_LINK_T14S_416=
TIDE_LINK_T14S_430=
TIDE_LINK_T14S_500=
TIDE_LINK_T14S_530=

# Secret you invent (long random string). Used to authenticate
# POST /api/webhooks/tide when marking an order paid + sending WhatsApp.
# Header: Authorization: Bearer <this value>
TIDE_WEBHOOK_SECRET=

# ── WhatsApp Business Cloud API (Meta) ──────────────────
# Leave blank until ready. Notification is skipped (and logged) if any required value is empty.
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Destination number in international format, digits only (e.g. 447411949215)
WHATSAPP_TO=
# Optional Graph API version
WHATSAPP_API_VERSION=v21.0
