# ── Server ──────────────────────────────────────────────
PORT=3000
# Public base URL of this site (no trailing slash). Used for success/cancel pages.
BASE_URL=http://localhost:3000

# ── Tide payments ───────────────────────────────────────
# Create one Instant Checkout / Payment Link in the Tide app for £250,
# then paste the full https://… URL below.
#
# Tide app → Instant Checkout / Payment Links
# Product id: t14-gen1-250  →  env key:
TIDE_LINK_T14_GEN1_250=

# Secret you invent (long random string). Authenticates
# POST /api/webhooks/tide when marking an order paid + sending WhatsApp.
# Header: Authorization: Bearer <this value>
TIDE_WEBHOOK_SECRET=

# ── WhatsApp Business Cloud API (Meta) ──────────────────
# Leave blank until ready. Notification is skipped if empty.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Destination number, digits only (e.g. 447411949215)
WHATSAPP_TO=
WHATSAPP_API_VERSION=v21.0
